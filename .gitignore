# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code local/personal state
.claude/settings.local.json
.claude/agent-memory/

# data-engineer diagnostic scripts (gate 4: lifecycle 즉시 삭제, git commit 금지)
/scripts/_diag/

# typescript
*.tsbuildinfo
next-env.d.ts
.reminder-flag.md
.claude/scheduled_tasks.lock
