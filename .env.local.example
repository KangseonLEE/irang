# data.go.kr (기상청 ASOS, 심평원 병원정보 공통)
DATA_GO_KR_API_KEY=발급받은_인코딩_키

# SGIS 오픈플랫폼 (인구·가구·고령화율)
SGIS_KEY=서비스ID
SGIS_SECRET=보안KEY

# KOSIS Open API (작물 재배면적·생산량)
KOSIS_API_KEY=발급받은_인증키

# NEIS 교육정보 Open API (학교 수)
# https://open.neis.go.kr 에서 별도 가입 + 인증키 발급
NEIS_API_KEY=발급받은_인증키

# Unsplash API (지역/작물 이미지)
# https://unsplash.com/developers 에서 발급 (Demo: 50 req/hr)
UNSPLASH_ACCESS_KEY=발급받은_Access_Key

# RDA 똑똑!청년농부 API (지원사업·교육·청년사례)
# https://www.rda.go.kr/young/main/api/writeForm.do 에서 신청
RDA_API_KEY=발급받은_서비스키

# Naver News Search API (농촌 뉴스 자동 갱신)
# https://developers.naver.com 에서 앱 등록 후 발급 (검색 API 선택)
NAVER_CLIENT_ID=발급받은_Client_ID
NAVER_CLIENT_SECRET=발급받은_Client_Secret

# Google Analytics 4
# 1. https://analytics.google.com 에서 속성 생성
# 2. 관리 > 데이터 스트림 > 웹 > 측정 ID 복사
# 비워두면 GA4 비활성화 (개발 환경에서는 설정하지 않아도 됨)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Supabase (지원사업·교육·행사 데이터 DB)
# https://supabase.com 에서 프로젝트 생성 후 Settings > API 에서 확인
# 비워두면 기존 정적 데이터(.ts) 사용 (폴백)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 피드백 Google Form URL
# 비워두면 Footer 피드백 버튼 비표시
NEXT_PUBLIC_FEEDBACK_URL=https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform
