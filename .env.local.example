# Supabase
# 1. https://supabase.com 에서 프로젝트 생성
# 2. Settings > API 에서 아래 값 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# data.go.kr (기상청 ASOS, 심평원 병원정보 공통)
DATA_GO_KR_API_KEY=발급받은_인코딩_키

# SGIS 오픈플랫폼 (인구·가구·고령화율)
SGIS_CONSUMER_KEY=서비스ID
SGIS_CONSUMER_SECRET=보안KEY

# KOSIS Open API (작물 재배면적·생산량)
KOSIS_API_KEY=발급받은_인증키

# NEIS 교육정보 Open API (학교 수)
# https://open.neis.go.kr 에서 별도 가입 + 인증키 발급
NEIS_API_KEY=발급받은_인증키

# Google Analytics 4
# 1. https://analytics.google.com 에서 속성 생성
# 2. 관리 > 데이터 스트림 > 웹 > 측정 ID 복사
# 비워두면 GA4 비활성화 (개발 환경에서는 설정하지 않아도 됨)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
